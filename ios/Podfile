# Cleona iOS — CocoaPods dependency file
#
# Native crypto/audio/codec libraries are built as static .a files by
# scripts/build-ios-libs.sh and packaged as XCFrameworks in
# build/ios-frameworks/. The CleonaNative podspec links them into the Runner
# binary so dart:ffi can access symbols via DynamicLibrary.process().

platform :ios, '15.5'

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. Run `flutter pub get` first."
  end
  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}."
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

target 'Runner' do
  use_frameworks! :linkage => :static
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  # Prebuilt native libs (libsodium, liboqs, libzstd, etc.)
  # Built by scripts/build-ios-libs.sh → build/ios-frameworks/*.xcframework
  pod 'CleonaNative', :path => 'CleonaNative'
end

target 'RunnerTests' do
  inherit! :search_paths
end

post_install do |installer|
  # dart:ffi loads native symbols at runtime via DynamicLibrary.process().
  # The linker dead-strips them because nothing references them at compile
  # time. -force_load on the Runner target ensures all symbols survive.
  ffi_libs = %w[libsodium liboqs libzstd libopus libcleona_audio libwhisper libggml]
  force_flags = []
  cn_pod = installer.pod_targets.find { |t| t.name == 'CleonaNative' }
  if cn_pod
    cn_pod.file_accessors.each do |fa|
      fa.vendored_frameworks.each do |fw|
        name = File.basename(fw.to_s, '.xcframework')
        next unless ffi_libs.include?(name)
        # Xcode resolves the arch slice at build time; use the build-products path
        lib_a = "#{fw}/ios-arm64/#{name}.a"
        force_flags << "-force_load #{lib_a}" if File.exist?(lib_a)
      end
    end
  end

  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.5'
    end
  end

  # Apply -force_load to the main app target
  if force_flags.any?
    installer.aggregate_targets.each do |agg|
      agg.xcconfigs.each do |config_name, config|
        force_flags.each { |f| config.other_linker_flags[:simple] << f }
        xcconfig_path = agg.xcconfig_path(config_name)
        config.save_as(xcconfig_path)
      end
    end
  end
end
